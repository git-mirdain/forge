{
  "inlay_hints": {
    "enabled": true
  },
  "terminal": {
    "env": {
      "PATH": "target/debug:$PATH",
      "MANPATH": "$PWD/target/share/man:$MANPATH"
    }
  },
  "lsp": {
    "forge-lsp": {
      "binary": {
        "path": "target/debug/forge-lsp"
      }
    }
  },
  "context_servers": {
    "forge-mcp": {
      "source": "custom",
      "command": {
        "path": "target/debug/forge-mcp",
        "args": []
      }
    }
  }
}
